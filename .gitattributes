# Repo dictates its own line-ending physics; local core.autocrlf settings are irrelevant.
# (Added 2026-06-10 after transient CRLF churn polluted the working tree during review.)
* text=auto

# Test fixtures are byte-exact oracle inputs/outputs — never convert line endings
# (the tokenizer/PPL gates compare against bytes the stock llama.cpp saw).
tests/fixtures/** -text

# Binary artifacts — never text-process
*.gguf -text
*.sp-model -text
*.sp-tokenizer -text
*.bin -text
*.pt -text
*.spt -text
