//============================================================================
// sp_hex.idl — Phase 2-HX FastRPC interface (Hexagon V69 HTP).
//
// Recreated fresh for shannon-prime-system-engine. The C:\Qualcomm\Hexagon_IDE
// \S22U project + the SDK examples are STRUCTURAL REFERENCE ONLY — no code copied.
//
// Architecture (settled, see SESSION-STATE-lat-2-HX): WHOLE-FORWARD-ON-DSP. The
// host (phone ARM) uploads each weight tensor once into its own rpcmem buffer
// (exact-alloc: IDL length == buffer bytes), then calls one forward method per
// prefill chunk; the cDSP runs the full gemma3/qwen3 forward in HVX and returns
// logits. ~2 FastRPC calls per chunk, mirroring the CUDA/Vulkan device-runs-the-
// forward pattern. (upload + forward methods land in HX.3a.)
//
// HX.2 = wiring smoke only: open/close + ping. Proves qaic + skel + stub +
// FastRPC + unsigned-PD round-trip with OUR IDL on R5CT22445JA before any kernel.
//============================================================================

#include "AEEStdDef.idl"
#include "remote.idl"

interface sp_hex : remote_handle64 {
   // y = x + 1, computed on the cDSP. HX.2 round-trip smoke.
   long ping(in long x, rout long y);

   // HX.3a: per-tensor weight upload (the rpcmem exact-alloc path the 574 MB Q8
   // arena uses). The host rpcmem_alloc's EXACTLY `data`'s length and passes it;
   // the DSP returns CRC-32 of the bytes it actually received. Host compares to
   // its own CRC-32 — a mismatch means the transfer is not byte-exact (the
   // exact-alloc / silent-zero-fill trap). `crc` is the CRC bits in an int32.
   long upload_crc(in sequence<uint8> data, rout long crc);

   // HX.3a: scalar f32 matmul on the cDSP — y[j] = sum_i w[j*cols + i] * x[i],
   // j in [0,rows) (ggml weight layout: row j is `cols` contiguous f32; one
   // token). Proves the DSP f32 compute kernel + the float data path are correct
   // (host compares to its own dot) before the whole forward is assembled on it.
   long matmul_f32(in sequence<float> w, in long rows, in long cols,
                   in sequence<float> x, rout sequence<float> y);

   // HX.3a: run the gemma3 transformer LAYERS + final output RMSNorm on the cDSP.
   // The host does the embedding lookup (×√n_embd) and the tied LM head; this
   // takes the embedded hidden `x` [n_tok*n_embd], the Q8/f32 weight blob
   // (sp_hex_layout.h), a `scratch` work buffer (sp_hex_scratch_elems), and writes
   // the final-normed hidden `hidden` [n_tok*n_embd]. Scalar f32 for HX.3a (gated
   // == on-phone CPU Q8 PPL); HX.3b swaps the matmul to qf32 HVX.
   long forward(in long n_layers, in long n_embd, in long n_ff, in long head_dim,
                in long n_head, in long n_head_kv, in long sliding_window,
                in float eps, in float rope_global, in float rope_local,
                in long n_tok, in sequence<float> x, in sequence<uint8> weights,
                in sequence<float> scratch, rout sequence<float> hidden);
};
