#version 450
/* silu_mul.comp — SwiGLU (Qwen3 FFN): g = silu(g) * up, silu(x) = x/(1+exp(-x)).
 * Mirrors CUDA k_silu_mul. Dispatch: (ceil(n/256), 1, 1). */

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) buffer Gbuf { float g[]; };          /* in/out */
layout(std430, binding = 1) readonly buffer Ubuf { float up[]; };

layout(push_constant) uniform PC { uint n; } pc;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < pc.n) {
        float x = g[idx];
        g[idx] = (x / (1.0 + exp(-x))) * up[idx];
    }
}
